# Copy this file to .env and fill in real values before starting the server

# MongoDB connection string (local dev default)
MONGO_URI=mongodb://localhost:27017/moise_ads

# JWT secret — GENERATE A STRONG RANDOM STRING FOR PRODUCTION
# Example: openssl rand -base64 64
JWT_SECRET=change_me_to_a_long_random_string

# Token expiry (e.g. 7d, 24h, 30m)
JWT_EXPIRES_IN=7d

# Server port
PORT=5000

# Allowed CORS origins (comma-separated) — frontend URL
CORS_ORIGIN=http://localhost:5173

# Seed admin credentials (used only on first seed run)
SEED_RAY_EMAIL=ray@moisecare.nl
SEED_RAY_PASSWORD=change_this_password
SEED_AGENCY_EMAIL=agency@example.com
SEED_AGENCY_PASSWORD=change_this_password
